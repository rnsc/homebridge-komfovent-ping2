{
  "pluginAlias": "KomfoventPing2",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Device Name",
              "type": "string",
              "required": true
            },
            "host": {
              "title": "Host",
              "type": "string",
              "required": true,
              "description": "IP address or hostname of the PING2 module"
            },
            "port": {
              "title": "Modbus TCP Port",
              "type": "integer",
              "default": 502,
              "description": "Modbus TCP port (default: 502)"
            },
            "slaveId": {
              "title": "Modbus Slave ID",
              "type": "integer",
              "default": 1,
              "minimum": 1,
              "maximum": 254,
              "description": "Modbus slave ID (default: 1)"
            },
            "deviceId": {
              "title": "Device ID",
              "type": "string",
              "required": true,
              "pattern": "^[A-Za-z0-9_]{16}$",
              "description": "Unique 16-character ID (letters, digits, underscore) for HomeKit UUID generation"
            }
          }
        }
      }
    }
  }
}
